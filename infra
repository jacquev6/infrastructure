#!/bin/bash

set -o errexit

INFRASTRUCTURE_TOOLS_TAG=20190222-190905

TTY_OPTION=""

if [ -t 0 ]
then
  TTY_OPTION="--tty"
fi

docker run --rm --name infrastructure-tools --interactive $TTY_OPTION \
  --mount type=bind,src=$PWD,dst=/infrastructure \
  jacquev6/infrastructure-tools:$INFRASTRUCTURE_TOOLS_TAG \
  -- "$@"
